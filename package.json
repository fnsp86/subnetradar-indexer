{
  "name": "bittensor-squid",
  "private": true,
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "rm -rf lib && tsc",
    "db:migrate": "npx squid-typeorm-migration apply",
    "db:generate": "npx squid-typeorm-migration generate",
    "codegen": "npx squid-typeorm-codegen",
    "typegen": "npx squid-substrate-typegen ./typegen.json",
    "process": "node --require=dotenv/config lib/main.js",
    "serve": "npx squid-graphql-server"
  },
  "dependencies": {
    "@subsquid/graphql-server": "^4.6.0",
    "@subsquid/ss58": "^2.0.2",
    "@subsquid/substrate-processor": "^8.4.1",
    "@subsquid/typeorm-migration": "^1.3.0",
    "@subsquid/typeorm-store": "^1.5.1",
    "@subsquid/util-internal": "^3.0.0",
    "dotenv": "^16.4.5",
    "pg": "8.12.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@subsquid/substrate-typegen": "^8.1.0",
    "@subsquid/typeorm-codegen": "^2.0.1",
    "@types/node": "^20.14.8",
    "typescript": "^5.5.2"
  }
}
